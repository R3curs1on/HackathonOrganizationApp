{
  "expo": {
    "name": "ACM VIT Hackathon",
    "slug": "breaking-enigma-console",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/acm-brand.png",
    "scheme": "breakingenigma",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.acm.breakingenigma.console",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.acm.breakingenigma.console",
      "versionCode": 1,
      "permissions": [
        "VIBRATE",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0a0d14",
        "foregroundImage": "./assets/images/acm-brand-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/acm-brand-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/acm-brand.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0d14",
          "dark": {
            "backgroundColor": "#0a0d14"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Breaking Enigma Console to use camera for QR scanning."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a8b28958-f44a-434f-afc0-97d0e9be9798"
      }
    }
  }
}
